{
  "name": "zconfigio",
  "packageManager": "yarn@4.13.0",
  "license": "GPL-3.0-or-later",
  "type": "module",
  "main": "./src/ZConfigIo.js",
  "exports": {
    ".": {
      "import": "./src/ZConfigIo.js",
      "types": "./src/ZConfigIo.d.ts"
    }
  },
  "files": [
    "/src",
    "/tsconfig.json",
    "/.yarn",
    "/.yarnrc.yml",
    "/yarn.lock"
  ],
  "preferUnplugged": true,
  "scripts": {
    "build": "tsc",
    "postinstall": "yarn dlx -p typescript tsc",
    "watch": "tsc --watch"
  },
  "dependencies": {
    "@types/node": "^24.12.0",
    "confbox": "^0.2.4",
    "typebox": "^1.1.7",
    "typescript": "^6.0.2"
  }
}
